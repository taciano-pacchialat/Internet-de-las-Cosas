    {
        "id": "func_format_fence_mqtt",
        "type": "function",
        "z": "flow_tab_geofence_api",
        "name": "Validar & Empaquetar ESP32 Payload",
        "func": "var body = msg.payload || {};\nvar vertices = body.vertices || [];\nif (!Array.isArray(vertices) || vertices.length < 3) {\n    msg.payload = { status: \"error\", message: \"Pol\u00edgono inv\u00e1lido: m\u00ednimo 3 v\u00e9rtices requeridos.\" };\n    msg.statusCode = 400;\n    return [null, msg];\n}\nvar min_lat = vertices[0].lat, max_lat = vertices[0].lat;\nvar min_lon = vertices[0].lon, max_lon = vertices[0].lon;\nfor (var i = 1; i < vertices.length; i++) {\n    if (vertices[i].lat < min_lat) min_lat = vertices[i].lat;\n    if (vertices[i].lat > max_lat) max_lat = vertices[i].lat;\n    if (vertices[i].lon < min_lon) min_lon = vertices[i].lon;\n    if (vertices[i].lon > max_lon) max_lon = vertices[i].lon;\n}\nvar esp32Payload = {\n    command: \"UPDATE_GEOFENCE\",\n    min_lat: min_lat,\n    max_lat: max_lat,\n    min_lon: min_lon,\n    max_lon: max_lon,\n    vertex_count: vertices.length,\n    vertices: vertices,\n    timestamp: Math.floor(Date.now() / 1000)\n};\nvar mqttMsg = {\n    topic: \"geofence/config_update\",\n    payload: JSON.stringify(esp32Payload),\n    qos: 1,\n    retain: true\n};\nmsg.statusCode = 200;\nmsg.payload = {\n    status: \"success\",\n    message: \"Geofence actualizado con \" + vertices.length + \" v\u00e9rtices y publicado por MQTT.\",\n    topic: \"geofence/config_update\",\n    timestamp: esp32Payload.timestamp\n};\nreturn [mqttMsg, msg];",
        "outputs": 2,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 450,
        "y": 140,
        "wires": [
            [
                "mqtt_out_config_update"
            ],
            [
                "http_resp_update_fence"
            ]
        ]
    },
