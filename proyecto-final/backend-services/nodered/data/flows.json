    {
        "id": "parse_heartbeat",
        "type": "function",
        "z": "flow_tab_mqtt_influx",
        "name": "Parsear Heartbeat",
        "func": "var data = (typeof msg.payload === \"string\") ? JSON.parse(msg.payload) : (msg.payload || {});\nvar raw = data.raw || data;\nvar rssiVal = (data.rssi !== undefined) ? data.rssi : raw.rssi;\nvar snrVal = (data.snr !== undefined) ? data.snr : raw.snr;\n\nvar fields = {\n    latitude: parseFloat(raw.lat) || 0.0,\n    longitude: parseFloat(raw.lon) || 0.0,\n    rssi: parseInt(rssiVal) || 0,\n    snr: parseFloat(snrVal) || 0.0,\n    battery: parseFloat(raw.battery) || 100.0,\n    wake_count: parseInt(raw.wake_count) || 0\n};\nvar tags = {\n    device_id: raw.device_id || \"edge-01\",\n    fence_status: raw.fence_status || \"UNKNOWN\"\n};\nmsg.payload = [fields, tags];\nreturn msg;",
        "outputs": 1,
        "x": 370,
        "y": 120,
        "wires": [
            [
                "influx_write",
                "debug_heartbeat"
            ]
        ]
    },
