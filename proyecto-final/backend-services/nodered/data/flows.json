    {
        "id": "mqtt_in_heartbeat",
        "type": "mqtt in",
        "z": "flow_tab_mqtt_influx",
        "name": "Heartbeat MQTT",
        "topic": "geofence/heartbeat",
        "qos": "1",
        "datatype": "json",
        "broker": "mqtt_broker_config",
        "nl": false,
        "rap": true,
        "rh": 0,
        "inputs": 0,
        "x": 130,
        "y": 120,
        "wires": [
            [
                "parse_heartbeat"
            ]
        ]
    },
    {
        "id": "parse_heartbeat",
        "type": "function",
        "z": "flow_tab_mqtt_influx",
        "name": "Parsear Heartbeat",
        "func": "var data = msg.payload;\nvar fields = {\n    latitude: parseFloat(data.lat) || 0.0,\n    longitude: parseFloat(data.lon) || 0.0,\n    rssi: parseInt(data.rssi) || 0,\n    snr: parseFloat(data.snr) || 0.0,\n    battery: parseFloat(data.battery) || 0.0,\n    wake_count: parseInt(data.wake_count) || 0\n};\nvar tags = {\n    device_id: data.device_id || \"edge-unknown\",\n    fence_status: data.fence_status || \"UNKNOWN\"\n};\nmsg.payload = [fields, tags];\nreturn msg;",
        "outputs": 1,
        "x": 370,
        "y": 120,
        "wires": [
            [
                "influx_write",
                "debug_heartbeat"
            ]
        ]
    },
    {
        "id": "debug_heartbeat",
