    {
        "id": "telegram_receiver",
        "type": "comment",
        "z": "flow_tab_telegram",
        "name": "⚠️ CONFIGURAR: Nodo 'telegram receiver' — Token: TU_TOKEN_AQUI",
        "info": "Pasos:\n1. Instalar node-red-contrib-telegrambot\n2. Agregar nodo 'telegram receiver'\n3. En la config del bot, poner el token de @BotFather\n4. Conectar la salida al nodo function de abajo\n\nComando esperado: /posicion",
        "x": 340,
        "y": 80,
        "wires": []
    },
    {
        "id": "telegram_query_func",
        "type": "function",
        "z": "flow_tab_telegram",
        "name": "Consultar última posición (InfluxDB query)",
        "func": "msg.query = 'SELECT last(\"latitude\"), last(\"longitude\"), \"fence_status\" FROM \"cattle_position\" GROUP BY \"device_id\"';\nreturn msg;",
        "outputs": 1,
        "x": 340,
        "y": 160,
        "wires": [
            []
        ]
    },
    {
        "id": "telegram_format_response",
        "type": "function",
        "z": "flow_tab_telegram",
        "name": "Formatear respuesta Telegram",
        "func": "var results = msg.payload;\nvar text = '🐄 *Última posición del ganado:*\\n\\n';\nif (results && results.length > 0) {\n    results.forEach(function(r) {\n        text += '📍 Device: ' + (r.device_id || 'N/A') + '\\n';\n        text += '   Lat: ' + (r.last_latitude || 'N/A') + '\\n';\n        text += '   Lon: ' + (r.last_longitude || 'N/A') + '\\n';\n        text += '   Estado: ' + (r.fence_status || 'N/A') + '\\n\\n';\n    });\n} else {\n    text += 'No hay datos disponibles aún.';\n}\nmsg.payload = { chatId: msg.originalMessage.chat.id, type: 'message', content: text, options: { parse_mode: 'Markdown' } };\nreturn msg;",
        "outputs": 1,
        "x": 340,
        "y": 240,
        "wires": [
            []
        ]
    },
    {
        "id": "telegram_sender_comment",
        "type": "comment",
        "z": "flow_tab_telegram",
        "name": "⚠️ CONFIGURAR: Nodo 'telegram sender' — Token: TU_TOKEN_AQUI",
        "info": "Agregar nodo 'telegram sender' aquí.\nConfigurar con el mismo bot token de arriba.\nConectar la salida del nodo 'Formatear respuesta' a este sender.",
        "x": 340,
        "y": 320,
        "wires": []
    },
    {
        "id": "gps_combiner",
        "type": "function",
        "z": "flow_tab_gps_sim",
        "name": "Combinar Lat/Lon y Publicar",
        "func": "var lat = flow.get('sim_lat') || -34.9205;\nvar lon = flow.get('sim_lon') || -57.9536;\nif (msg.topic === 'lat') { flow.set('sim_lat', parseFloat(msg.payload)); return null; }\nif (msg.topic === 'lon') { flow.set('sim_lon', parseFloat(msg.payload)); return null; }\nlat = flow.get('sim_lat') || -34.9205;\nlon = flow.get('sim_lon') || -57.9536;\nmsg.payload = JSON.stringify({ lat: lat, lon: lon, timestamp: new Date().toISOString() });\nmsg.retain = true;\nnode.status({fill:'green', shape:'dot', text: lat.toFixed(4) + ', ' + lon.toFixed(4)});\nreturn msg;",
        "outputs": 1,
        "x": 420,
        "y": 170,
        "wires": [
            [
                "mqtt_out_simgps",
                "debug_simgps"
            ]
        ]
    },
