# ==============================================================================
# Backend Services (Docker, Node-RED, InfluxDB, Mosquitto, Grafana)
# ==============================================================================
# Ignore runtime data and logs, but keep directory structure (.gitkeep files)
backend-services/mosquitto/data/*
!backend-services/mosquitto/data/.gitkeep
backend-services/mosquitto/log/*
!backend-services/mosquitto/log/.gitkeep

backend-services/influxdb/data/*
!backend-services/influxdb/data/.gitkeep

backend-services/nodered/data/*
!backend-services/nodered/data/.gitkeep
!backend-services/nodered/data/flows.json

backend-services/grafana/data/*
!backend-services/grafana/data/.gitkeep

